#: plugin.py:47
msgid ""
"Looks up Ferengi Rules of Acquisition from Star Trek by number or\n"
"    keyword, and returns a random rule when called with no arguments."
msgstr ""
"Looks up Ferengi Rules of Acquisition from Star Trek by number or\n"
"    keyword, and returns a random rule when called with no arguments."

#: plugin.py:52
msgid ""
"[<number> | <search term>]\n"
"\n"
"        Returns a Rule of Acquisition (aphorisms, guidelines and principles\n"
"        that provide the foundation of business in Ferengi culture). With no\n"
"        argument a random rule is returned. A search term that matches\n"
"        multiple rules returns a random one of those."
msgstr ""
"[<number> | <search term>]\n"
"\n"
"        Returns a Rule of Acquisition (aphorisms, guidelines and principles\n"
"        that provide the foundation of business in Ferengi culture). With no\n"
"        argument a random rule is returned. A search term that matches\n"
"        multiple rules returns a random one of those."

#: plugin.py:65
msgid "404 - Rule not found."
msgstr "404 - Rule not found."

#: plugin.py:70
msgid "404 - Rule not found."
msgstr "404 - Rule not found."
