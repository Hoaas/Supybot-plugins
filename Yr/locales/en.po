#: plugin.py
msgid "[#channel] <city>\n\nSearches for location from geonames.org and uses coordinates found there to fetch a weather forecast from the met.no API."
msgstr "[#channel] <city>\n\nSearches for location from geonames.org and uses coordinates found there to fetch a weather forecast from the met.no API."

#: plugin.py
msgid "[#channel] <city>\n\nShows sunrise and sunset times for the given location."
msgstr "[#channel] <city>\n\nShows sunrise and sunset times for the given location."

#: plugin.py
msgid "Lists the 3 hottest and 3 coldest places in Norway with their temperatures."
msgstr "Lists the 3 hottest and 3 coldest places in Norway with their temperatures."

