#: plugin.py
msgid "[#channel] <city>\n\nSearches for location from geonames.org and uses coordinates found there to fetch a weather forecast from the met.no API."
msgstr "[#channel] <sted>\n\nSøker etter sted på geonames.org og bruker koordinatene derfra til å hente værvarsel fra met.no sitt API."

#: plugin.py
msgid "[#channel] <city>\n\nShows sunrise and sunset times for the given location."
msgstr "[#channel] <sted>\n\nViser soloppgang og solnedgang for oppgitt sted."

#: plugin.py
msgid "Lists the 3 hottest and 3 coldest places in Norway with their temperatures."
msgstr "Viser de 3 varmeste og 3 kaldeste stedene i Norge med temperaturer."

#: plugin.py
msgid "\"%s\" not found at geonames.org"
msgstr "\"%s\" ble ikke funnet på geonames.org"

